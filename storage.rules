rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper
    function isStaff() {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid))
          .data.rol in ["admin", "entrenador"] &&
        firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid))
          .data.activo != false;
    }

    function isAdmin() {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid))
          .data.rol == "admin" &&
        firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid))
          .data.activo != false;
    }

    function maxSize(mb) {
      return request.resource.size < mb * 1024 * 1024;
    }

    function isImage() {
      return request.resource.contentType.matches("image/.*");
    }

    // ─── GALERÍA ─────────────────────────────────────────
    match /galeria/{fileName} {
      allow read:  if true;
      allow write: if isStaff() && maxSize(10) && isImage();
      allow delete: if isAdmin();
    }

    // ─── NOTICIAS ────────────────────────────────────────
    match /noticias/{fileName} {
      allow read:  if true;
      allow write: if isStaff() && maxSize(10) && isImage();
      allow delete: if isAdmin();
    }

    // ─── FORO ────────────────────────────────────────────
    match /foro/{fileName} {
      allow read:  if request.auth != null;
      allow write: if isStaff() && maxSize(10) && isImage();
      allow delete: if isAdmin();
    }

    // ─── FOTOS JUGADORES ─────────────────────────────────
    match /jugadores/{jugadorId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if isAdmin() && maxSize(5) && isImage();
      allow delete: if isAdmin();
    }

    // ─── BLOQUEAR TODO LO DEMÁS ──────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
